          "attributes": {
            "id": "2583142299",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"AllowScopedEC2InstanceAccessActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:RunInstances\",\n        \"ec2:CreateFleet\"\n      ],\n      \"Resource\": [\n        \"arn:aws:ec2:us-east-1::snapshot/*\",\n        \"arn:aws:ec2:us-east-1::image/*\",\n        \"arn:aws:ec2:us-east-1:*:subnet/*\",\n        \"arn:aws:ec2:us-east-1:*:security-group/*\",\n        \"arn:aws:ec2:us-east-1:*:placement-group/*\",\n        \"arn:aws:ec2:us-east-1:*:capacity-reservation/*\"\n      ]\n    },\n    {\n      \"Sid\": \"AllowScopedEC2LaunchTemplateAccessActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:RunInstances\",\n        \"ec2:CreateFleet\"\n      ],\n      \"Resource\": \"arn:aws:ec2:us-east-1:*:launch-template/*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:ResourceTag/kubernetes.io/cluster/eks-devops-senior\": \"owned\"\n        },\n        \"StringLike\": {\n          \"aws:ResourceTag/karpenter.sh/nodepool\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedEC2InstanceActionsWithTags\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:RunInstances\",\n        \"ec2:CreateLaunchTemplate\",\n        \"ec2:CreateFleet\"\n      ],\n      \"Resource\": [\n        \"arn:aws:ec2:us-east-1:*:volume/*\",\n        \"arn:aws:ec2:us-east-1:*:spot-instances-request/*\",\n        \"arn:aws:ec2:us-east-1:*:network-interface/*\",\n        \"arn:aws:ec2:us-east-1:*:launch-template/*\",\n        \"arn:aws:ec2:us-east-1:*:instance/*\",\n        \"arn:aws:ec2:us-east-1:*:fleet/*\",\n        \"arn:aws:ec2:us-east-1:*:capacity-reservation/*\"\n      ],\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:RequestTag/eks:eks-cluster-name\": \"eks-devops-senior\",\n          \"aws:RequestTag/kubernetes.io/cluster/eks-devops-senior\": \"owned\"\n        },\n        \"StringLike\": {\n          \"aws:RequestTag/karpenter.sh/nodepool\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedResourceCreationTagging\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"ec2:CreateTags\",\n      \"Resource\": [\n        \"arn:aws:ec2:us-east-1:*:volume/*\",\n        \"arn:aws:ec2:us-east-1:*:spot-instances-request/*\",\n        \"arn:aws:ec2:us-east-1:*:network-interface/*\",\n        \"arn:aws:ec2:us-east-1:*:launch-template/*\",\n        \"arn:aws:ec2:us-east-1:*:instance/*\",\n        \"arn:aws:ec2:us-east-1:*:fleet/*\"\n      ],\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:RequestTag/eks:eks-cluster-name\": \"eks-devops-senior\",\n          \"aws:RequestTag/kubernetes.io/cluster/eks-devops-senior\": \"owned\",\n          \"ec2:CreateAction\": [\n            \"RunInstances\",\n            \"CreateFleet\",\n            \"CreateLaunchTemplate\"\n          ]\n        },\n        \"StringLike\": {\n          \"aws:RequestTag/karpenter.sh/nodepool\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedResourceTagging\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"ec2:CreateTags\",\n      \"Resource\": \"arn:aws:ec2:us-east-1:*:instance/*\",\n      \"Condition\": {\n        \"ForAllValues:StringEquals\": {\n          \"aws:TagKeys\": [\n            \"eks:eks-cluster-name\",\n            \"karpenter.sh/nodeclaim\",\n            \"Name\"\n          ]\n        },\n        \"StringEquals\": {\n          \"aws:ResourceTag/kubernetes.io/cluster/eks-devops-senior\": \"owned\"\n        },\n        \"StringEqualsIfExists\": {\n          \"aws:RequestTag/eks:eks-cluster-name\": \"eks-devops-senior\"\n        },\n        \"StringLike\": {\n          \"aws:ResourceTag/karpenter.sh/nodepool\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedDeletion\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:TerminateInstances\",\n        \"ec2:DeleteLaunchTemplate\"\n      ],\n      \"Resource\": [\n        \"arn:aws:ec2:us-east-1:*:launch-template/*\",\n        \"arn:aws:ec2:us-east-1:*:instance/*\"\n      ],\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:ResourceTag/kubernetes.io/cluster/eks-devops-senior\": \"owned\"\n        },\n        \"StringLike\": {\n          \"aws:ResourceTag/karpenter.sh/nodepool\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowRegionalReadActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:DescribeSubnets\",\n        \"ec2:DescribeSpotPriceHistory\",\n        \"ec2:DescribeSecurityGroups\",\n        \"ec2:DescribePlacementGroups\",\n        \"ec2:DescribeLaunchTemplates\",\n        \"ec2:DescribeInstances\",\n        \"ec2:DescribeInstanceTypes\",\n        \"ec2:DescribeInstanceTypeOfferings\",\n        \"ec2:DescribeInstanceStatus\",\n        \"ec2:DescribeImages\",\n        \"ec2:DescribeCapacityReservations\",\n        \"ec2:DescribeAvailabilityZones\"\n      ],\n      \"Resource\": \"*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:RequestedRegion\": \"us-east-1\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowSSMReadActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"ssm:GetParameter\",\n      \"Resource\": \"arn:aws:ssm:us-east-1::parameter/aws/service/*\"\n    },\n    {\n      \"Sid\": \"AllowPricingReadActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"pricing:GetProducts\",\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"AllowZonalShiftReadActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"arc-zonal-shift:GetManagedResource\",\n      \"Resource\": \"*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"arc-zonal-shift:ResourceIdentifier\": \"arn:aws:eks:us-east-1:211125731695:cluster/eks-devops-senior\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowInterruptionQueueActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"sqs:ReceiveMessage\",\n        \"sqs:GetQueueUrl\",\n        \"sqs:DeleteMessage\"\n      ],\n      \"Resource\": \"arn:aws:sqs:us-east-1:211125731695:Karpenter-eks-devops-senior\"\n    },\n    {\n      \"Sid\": \"AllowPassingInstanceRole\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:PassRole\",\n      \"Resource\": \"arn:aws:iam::211125731695:role/Karpenter-eks-devops-senior-2026052522285619490000000d\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"iam:PassedToService\": \"ec2.amazonaws.com\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedInstanceProfileCreationActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:CreateInstanceProfile\",\n      \"Resource\": \"arn:aws:iam::211125731695:instance-profile/*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:RequestTag/eks:eks-cluster-name\": \"eks-devops-senior\",\n          \"aws:RequestTag/kubernetes.io/cluster/eks-devops-senior\": \"owned\",\n          \"aws:RequestTag/topology.kubernetes.io/region\": \"us-east-1\"\n        },\n        \"StringLike\": {\n          \"aws:RequestTag/karpenter.k8s.aws/ec2nodeclass\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedInstanceProfileTagActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:TagInstanceProfile\",\n      \"Resource\": \"arn:aws:iam::211125731695:instance-profile/*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:RequestTag/eks:eks-cluster-name\": \"eks-devops-senior\",\n          \"aws:RequestTag/kubernetes.io/cluster/eks-devops-senior\": \"owned\",\n          \"aws:RequestTag/topology.kubernetes.io/region\": \"us-east-1\",\n          \"aws:ResourceTag/kubernetes.io/cluster/eks-devops-senior\": \"owned\",\n          \"aws:ResourceTag/topology.kubernetes.io/region\": \"us-east-1\"\n        },\n        \"StringLike\": {\n          \"aws:RequestTag/karpenter.k8s.aws/ec2nodeclass\": \"*\",\n          \"aws:ResourceTag/karpenter.k8s.aws/ec2nodeclass\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowScopedInstanceProfileActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"iam:RemoveRoleFromInstanceProfile\",\n        \"iam:DeleteInstanceProfile\",\n        \"iam:AddRoleToInstanceProfile\"\n      ],\n      \"Resource\": \"arn:aws:iam::211125731695:instance-profile/*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"aws:ResourceTag/kubernetes.io/cluster/eks-devops-senior\": \"owned\",\n          \"aws:ResourceTag/topology.kubernetes.io/region\": \"us-east-1\"\n        },\n        \"StringLike\": {\n          \"aws:ResourceTag/karpenter.k8s.aws/ec2nodeclass\": \"*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"AllowInstanceProfileReadActions\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:GetInstanceProfile\",\n      \"Resource\": \"arn:aws:iam::211125731695:instance-profile/*\"\n    },\n    {\n      \"Sid\": \"AllowUnscopedInstanceProfileListAction\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:ListInstanceProfiles\",\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"AllowAPIServerEndpointDiscovery\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"eks:DescribeCluster\",\n      \"Resource\": \"arn:aws:eks:us-east-1:211125731695:cluster/eks-devops-senior\"\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Sid\":\"AllowScopedEC2InstanceAccessActions\",\"Effect\":\"Allow\",\"Action\":[\"ec2:RunInstances\",\"ec2:CreateFleet\"],\"Resource\":[\"arn:aws:ec2:us-east-1::snapshot/*\",\"arn:aws:ec2:us-east-1::image/*\",\"arn:aws:ec2:us-east-1:*:subnet/*\",\"arn:aws:ec2:us-east-1:*:security-group/*\",\"arn:aws:ec2:us-east-1:*:placement-group/*\",\"arn:aws:ec2:us-east-1:*:capacity-reservation/*\"]},{\"Sid\":\"AllowScopedEC2LaunchTemplateAccessActions\",\"Effect\":\"Allow\",\"Action\":[\"ec2:RunInstances\",\"ec2:CreateFleet\"],\"Resource\":\"arn:aws:ec2:us-east-1:*:launch-template/*\",\"Condition\":{\"StringEquals\":{\"aws:ResourceTag/kubernetes.io/cluster/eks-devops-senior\":\"owned\"},\"StringLike\":{\"aws:ResourceTag/karpenter.sh/nodepool\":\"*\"}}},{\"Sid\":\"AllowScopedEC2InstanceActionsWithTags\",\"Effect\":\"Allow\",\"Action\":[\"ec2:RunInstances\",\"ec2:CreateLaunchTemplate\",\"ec2:CreateFleet\"],\"Resource\":[\"arn:aws:ec2:us-east-1:*:volume/*\",\"arn:aws:ec2:us-east-1:*:spot-instances-request/*\",\"arn:aws:ec2:us-east-1:*:network-interface/*\",\"arn:aws:ec2:us-east-1:*:launch-template/*\",\"arn:aws:ec2:us-east-1:*:instance/*\",\"arn:aws:ec2:us-east-1:*:fleet/*\",\"arn:aws:ec2:us-east-1:*:capacity-reservation/*\"],\"Condition\":{\"StringEquals\":{\"aws:RequestTag/eks:eks-cluster-name\":\"eks-devops-senior\",\"aws:RequestTag/kubernetes.io/cluster/eks-devops-senior\":\"owned\"},\"StringLike\":{\"aws:RequestTag/karpenter.sh/nodepool\":\"*\"}}},{\"Sid\":\"AllowScopedResourceCreationTagging\",\"Effect\":\"Allow\",\"Action\":\"ec2:CreateTags\",\"Resource\":[\"arn:aws:ec2:us-east-1:*:volume/*\",\"arn:aws:ec2:us-east-1:*:spot-instances-request/*\",\"arn:aws:ec2:us-east-1:*:network-interface/*\",\"arn:aws:ec2:us-east-1:*:launch-template/*\",\"arn:aws:ec2:us-east-1:*:instance/*\",\"arn:aws:ec2:us-east-1:*:fleet/*\"],\"Condition\":{\"StringEquals\":{\"aws:RequestTag/eks:eks-cluster-name\":\"eks-devops-senio